import RPi.GPIO as GPIO
import time

# Initial Setup
GPIO.setmode(GPIO.BCM)
GPIO.setup(18, GPIO.OUT)

# Step 1: Initialize PWM on GPIO 18 at 60Hz
pwm18 = GPIO.PWM(18, 60)

try:
    # Step 4 & 5: Continuous Fade Loop
    pwm18.start(0)  # Start with 0% duty cycle
    print("Fading LED... Press Ctrl+C to stop.")

    while True:
        # Fade In: Loop from 0 to 100 in increments of 5
        for dutyCycle in range(0, 101, 5):
            pwm18.ChangeDutyCycle(dutyCycle)
            time.sleep(0.1)

        # Fade Out: Loop from 100 to 0 in increments of -5
        for dutyCycle in range(100, -1, -5):
            pwm18.ChangeDutyCycle(dutyCycle)
            time.sleep(0.1)

except KeyboardInterrupt:
    # Handle Step 5 requirements for graceful exit
    print("\nInterrupt received. Cleaning up...")

finally:
    # Ensure PWM stops and GPIO is cleared
    pwm18.stop()
    GPIO.cleanup()
